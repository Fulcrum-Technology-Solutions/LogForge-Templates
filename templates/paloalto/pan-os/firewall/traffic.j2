{# Define application groups with their related protocols and ports #}
{%- set app_groups = {
    'web': {
        'apps': ['web-browsing', 'ssl', 'http', 'https'],
        'protocol': 'tcp',
        'src_ports': range(49152, 65535),
        'dst_ports': [80, 443, 8080, 8443],
        'valid_actions': ['allow', 'deny', 'reset-client', 'reset-server', 'reset-both'],
        'rule_prefix': 'Web_'
    },
    'dns': {
        'apps': ['dns'],
        'protocol': 'udp',
        'src_ports': range(49152, 65535),
        'dst_ports': [53],
        'valid_actions': ['allow', 'deny', 'drop'],
        'rule_prefix': 'DNS_'
    },
    'file_sharing': {
        'apps': ['ftp', 'ms-ds-smb', 'netbios-ss'],
        'protocol': 'tcp',
        'src_ports': range(49152, 65535),
        'dst_ports': [21, 445, 139],
        'valid_actions': ['allow', 'deny', 'reset-client', 'reset-server', 'reset-both'],
        'rule_prefix': 'File_Sharing_'
    },
    'database': {
        'apps': ['mysql', 'ms-sql-m'],
        'protocol': 'tcp',
        'src_ports': range(49152, 65535),
        'dst_ports': [3306, 1433],
        'valid_actions': ['allow', 'deny', 'reset-client', 'reset-server', 'reset-both'],
        'rule_prefix': 'Database_'
    },
    'network': {
        'apps': ['icmp', 'ping', 'traceroute'],
        'protocol': 'icmp',
        'src_ports': [0],
        'dst_ports': [0],
        'valid_actions': ['allow', 'deny', 'drop'],
        'rule_prefix': 'Network_'
    },
    'tunneling': {
        'apps': ['unknown-tcp', 'unknown-udp'],
        'protocol': 'gre',
        'src_ports': [0],
        'dst_ports': [0],
        'valid_actions': ['allow', 'deny', 'drop'],
        'rule_prefix': 'Tunneling_'
    }
} -%}
{%- set log_sub_types = ['start', 'end', 'deny', 'drop'] -%}
{%- set log_sub_type = log_sub_types | random -%}

{%- set usernames = ['jsmith', 'alee', 'bjohnson', 'mwilliams', 'dthomas'] -%}
{%- set source_user = registry.get_random_user().username if registry.get_random_user() else usernames | random -%}
{%- set destination_user_names = ['unknown', 'admin', 'guest', 'external'] -%}
{%- set destination_user_name = destination_user_names | random -%}

{# Select a random application group #}
{%- set app_group_keys = app_groups.keys() | list -%}
{%- set selected_group = app_group_keys | random -%}
{%- set group = app_groups[selected_group] -%}

{# Now select appropriate values from the group #}
{%- set application = group.apps | random -%}
{%- set protocol = group.protocol -%}
{%- set source_port = group.src_ports | random -%}
{%- set destination_port = group.dst_ports | random -%}
{%- set action = group.valid_actions | random -%}
{# End random application group selection #}

{# Zone logic - certain zones make sense with certain traffic types #}
{%- set zone_pairs = {
    'internal': {
        'src': ['Trust', 'LAN', 'Internal'],
        'dst': ['Trust', 'LAN', 'Internal'],
        'typical_action': 'allow'
    },
    'outbound': {
        'src': ['Trust', 'LAN', 'Internal'],
        'dst': ['Untrust', 'Internet', 'External'],
        'typical_action': 'allow'
    },
    'inbound': {
        'src': ['Untrust', 'Internet', 'External'],
        'dst': ['DMZ', 'DMZ-In'],
        'typical_action': 'allow'
    },
    'blocked': {
        'src': ['Untrust', 'Internet', 'External'],
        'dst': ['Trust', 'LAN', 'Internal'],
        'typical_action': 'deny'
    }
} -%}

{# Select zone pair based on action #}
{%- if action == 'allow' -%}
    {%- set zone_options = ['internal', 'outbound', 'inbound'] -%}
{%- else -%}
    {%- set zone_options = ['blocked', 'inbound'] -%}
{%- endif -%}
{%- set selected_zone_pair = zone_pairs[zone_options | random] -%}
{%- set source_zone = selected_zone_pair.src | random -%}
{%- set destination_zone = selected_zone_pair.dst | random -%}

{# Generate rule name based on application group and action #}
{%- set action_prefix = '' -%}
{%- if action == 'allow' -%}
    {%- set action_prefix = 'Allow_' -%}
{%- elif action in ['deny', 'drop'] -%}
    {%- set action_prefix = 'Block_' -%}
{%- elif action.startswith('reset') -%}
    {%- set action_prefix = 'Reset_' -%}
{%- endif -%}

{%- set rule_name = action_prefix ~ group.rule_prefix ~ application | replace('-', '_') -%}

{%- set rule_variants = ['', '_Standard', '_Custom', '_Policy'] -%}
{%- set rule_name = rule_name ~ (rule_variants | random) -%}

{%- set common_ports = [53, 80, 443, 22, 21, 25, 445, 389, 123, 161, 3389, 139, 3306, 1433, 8080, 8443] -%}

{%- set categories = ['any', 'adult', 'alcohol-tobacco', 'auctions', 'business-economy', 'computer-internet-info', 'content-delivery-networks', 'cryptocurrency', 'dating', 'educational-institutions', 'entertainment-recreation', 'financial-services', 'gambling', 'games', 'government', 'health-medicine', 'high-risk', 'home-garden', 'hunting-fishing', 'insufficient-content', 'internet-communications-telephony', 'internet-portals', 'job-search', 'legal', 'military', 'motor-vehicles', 'news', 'not-resolved', 'nudity', 'online-storage-backup', 'peer-to-peer', 'personal-sites-blogs', 'philosophy-political-advocacy', 'private-ip-addresses', 'questionable', 'real-estate', 'reference-research', 'religion', 'search-engines', 'sex-education', 'shareware-freeware', 'shopping', 'social-networking', 'society-daily-living', 'sports', 'stock-advice-tools', 'streaming-media', 'swimsuits-lingerie', 'training-tools', 'translation', 'travel', 'web-advertisements', 'web-based-email', 'web-hosting', 'weapons', 'unknown', 'malware', 'phishing', 'command-and-control', 'hacking', 'proxy-avoidance-anonymizers'] -%}
{%- set category = categories | random -%}
{%- set src_countries = ['US', 'RU', 'CN', 'GB', 'DE', 'JP', 'FR', 'KR', 'IN', 'BR', 'CA', 'AU', 'NL', 'IT', 'ZA'] -%}
{%- set src_country = src_countries | random -%}
{%- set session_end_reasons = ['aged-out', 'policy-deny', 'policy-based-forward', 'tcp-fin', 'tcp-rst-from-client', 'tcp-rst-from-server', 'resources-unavailable', 'unknown', 'n/a'] -%}
{%- set session_end_reason = session_end_reasons | random -%}
{%- set src_dynamic_addr_groups = ['Corp-Internal', 'Corp-Workstations', 'Finance-Dept', 'Corp-BYOD', 'IT-Dept', 'HR-Dept', 'Engineering', 'Executive', 'Marketing', 'Sales', 'Data-Center', 'R&D', 'QA-Testing', 'Contractors'] -%}
{%- set src_dynamic_addr_group = src_dynamic_addr_groups | random -%}
{%- set dst_dynamic_addr_groups = ['DNS-Server', 'Web-Server', 'Mail-Server', 'File-Server', 'Database-Server', 'Application-Server', 'Authentication-Server', 'VPN-Gateway', 'Proxy-Server', 'IDS-IPS', 'Developer-Workstation', 'Executive-Laptop', 'Guest-Device', 'IoT-Device', 'SCADA-System', 'POS-Terminal', 'Mobile-Device', 'Unknown'] -%}
{%- set dst_dynamic_addr_group = dst_dynamic_addr_groups | random -%}
{%- set risks = ['low', 'medium', 'high', 'critical', 'informational'] -%}
{%- set risk = risks | random -%}
{%- set proxy_traffic_values = ['ProxyTraffic', 'NonProxyTraffic'] -%}
{%- set proxy_traffic_value = proxy_traffic_values | random -%}
{%- set tunnel_types = [0, 1, 2, 3, 5, 6] -%}
{%- set tunnel_type = tunnel_types | random -%}
{%- set serial_number = 'PA-5250-' ~ random_int(1000, 9999) -%}

1,{{ current_timestamp() | format_timestamp('%Y/%m/%d %H:%M:%S') }},{{ serial_number }},TRAFFIC,{{ log_sub_type }},{{ random_int(2000, 3000) }},{{ current_timestamp() | format_timestamp('%Y/%m/%d %H:%M:%S') }},{{ random_private_ip() }},{{ random_public_ip() }},{{ registry.get_random_device().ip_address if registry.get_random_device() else "10.10." + random_int(1, 5) | string + "." + random_int(1, 254) | string }},{{ random_public_ip() }},{{ rule_name }},{{ source_user }},{{ destination_user_name }},{{ application }},vsys1,{{ source_zone }},{{ destination_zone }},ethernet1/{{ random_int(1, 3) }},ethernet1/{{ random_int(1, 4) }},LogForward,,{{ random_int(54320, 54399) }},1,{{ source_port }},{{ destination_port }},{{ source_port }},{{ destination_port }},{{ random_hex(0, 67108864) }},{{ protocol }},{{ action }},{{ random_int(0, 150000) }},{{ random_int(0, 80000) }},{{ random_int(0, 70000) }},{{ random_int(0, 300) }},{{ current_timestamp() | format_timestamp('%Y/%m/%d %H:%M:%S') }},{{ random_int(0, 120) }},{{ category }},,{{ random_int(7892340, 7892399) }},0x0,US,{{ src_country }},,{{ random_int(0, 200) }},{{ random_int(0, 150) }},{{ session_end_reason }},DG1,DG2,,,vsys1,{{ serial_number }},policy,,,,,,,0,0,0,0,,0,0,0,0,0,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,{{ src_dynamic_addr_group }},{{ dst_dynamic_addr_group }},{{ proxy_traffic_value }},,,,,,{{ risk }},,,,,,,{{ tunnel_type }}
